<Window x:Class="Pop.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pop Settings"
        Width="560"
        Height="670"
        MinWidth="560"
        MinHeight="670"
        Background="#08111F"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#111D32" />
            <Setter Property="BorderBrush" Value="#243B5D" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F8FAFC" />
        </Style>

        <Style x:Key="SectionBodyStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AFC2DC" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="BodyCheckboxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#07111D" Offset="0" />
                <GradientStop Color="#0D182B" Offset="0.52" />
                <GradientStop Color="#15142A" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="20,20,20,14"
                Padding="22"
                CornerRadius="26"
                BorderBrush="#2E4C74"
                BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#112443" Offset="0" />
                    <GradientStop Color="#162E57" Offset="0.55" />
                    <GradientStop Color="#332047" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#F8FAFC"
                               Text="Pop" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#D9E7F8"
                               TextWrapping="Wrap"
                               Text="Polish the throw, keep the behavior familiar, and tune the parts that matter without getting lost in extra controls." />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="12,8"
                        CornerRadius="999"
                        Background="#2C3D5B"
                        BorderBrush="#466A98"
                        BorderThickness="1"
                        VerticalAlignment="Top">
                    <TextBlock Foreground="#E6F2FF"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="Momentum Snap" />
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Margin="20,0,20,0"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Behavior" />
                        <TextBlock Margin="0,6,0,18"
                                   Style="{StaticResource SectionBodyStyle}"
                                   Text="These controls keep the feature easy to live with day to day. The gesture itself stays the same; you are only toggling when and how Pop participates." />

                        <StackPanel Margin="0,0,0,14">
                            <CheckBox Style="{StaticResource BodyCheckboxStyle}"
                                      IsChecked="{Binding Enabled}"
                                      Content="Enable Pop momentum snapping" />
                            <TextBlock Margin="28,0,0,0"
                                       Style="{StaticResource SectionBodyStyle}"
                                       Text="Leave standard window dragging untouched until a fast horizontal release qualifies as a throw." />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,14">
                            <CheckBox Style="{StaticResource BodyCheckboxStyle}"
                                      IsChecked="{Binding ShowOverlay}"
                                      Content="Show the left/right target preview while dragging" />
                            <TextBlock Margin="28,0,0,0"
                                       Style="{StaticResource SectionBodyStyle}"
                                       Text="Keep the overlay subtle and helpful instead of noisy while you’re lining up a throw." />
                        </StackPanel>

                        <StackPanel>
                            <CheckBox Style="{StaticResource BodyCheckboxStyle}"
                                      IsChecked="{Binding LaunchAtStartup}"
                                      Content="Launch Pop when Windows starts" />
                            <TextBlock Margin="28,0,0,0"
                                       Style="{StaticResource SectionBodyStyle}"
                                       Text="Useful if you want the tray app ready without opening it manually each session." />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Tuning" />
                        <TextBlock Margin="0,6,0,18"
                                   Style="{StaticResource SectionBodyStyle}"
                                   Text="These values tune feel rather than features. Small changes can make the snap feel heavier, quicker, or more forgiving." />

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Foreground="#F8FAFC"
                                           FontWeight="SemiBold"
                                           Text="Throw velocity threshold" />
                                <TextBlock Style="{StaticResource SectionBodyStyle}"
                                           Text="Higher values demand a more deliberate flick. Lower values make Pop trigger more easily." />
                            </StackPanel>
                            <TextBox Grid.Column="1"
                                     Padding="12,10"
                                     Background="#091221"
                                     BorderBrush="#35527B"
                                     BorderThickness="1"
                                     Foreground="#F8FAFC"
                                     HorizontalContentAlignment="Center"
                                     Text="{Binding ThrowVelocityThresholdText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Foreground="#F8FAFC"
                                           FontWeight="SemiBold"
                                           Text="Horizontal dominance ratio" />
                                <TextBlock Style="{StaticResource SectionBodyStyle}"
                                           Text="Keeps vertical or diagonal drags from being mistaken for a left or right throw." />
                            </StackPanel>
                            <TextBox Grid.Column="1"
                                     Padding="12,10"
                                     Background="#091221"
                                     BorderBrush="#35527B"
                                     BorderThickness="1"
                                     Foreground="#F8FAFC"
                                     HorizontalContentAlignment="Center"
                                     Text="{Binding HorizontalDominanceRatioText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Foreground="#F8FAFC"
                                           FontWeight="SemiBold"
                                           Text="Glide duration" />
                                <TextBlock Style="{StaticResource SectionBodyStyle}"
                                           Text="Controls how long the settle animation lasts after release. Shorter values feel snappier; longer values emphasize momentum." />
                            </StackPanel>
                            <TextBox Grid.Column="1"
                                     Padding="12,10"
                                     Background="#091221"
                                     BorderBrush="#35527B"
                                     BorderThickness="1"
                                     Foreground="#F8FAFC"
                                     HorizontalContentAlignment="Center"
                                     Text="{Binding GlideDurationText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Advanced" />
                        <TextBlock Margin="0,6,0,18"
                                   Style="{StaticResource SectionBodyStyle}"
                                   Text="Diagnostics help tune thresholds and inspect unsupported-window cases. They stay local to this PC and do not change the feature’s behavior." />

                        <StackPanel>
                            <CheckBox Style="{StaticResource BodyCheckboxStyle}"
                                      IsChecked="{Binding EnableDiagnostics}"
                                      Content="Write lightweight local diagnostics" />
                            <TextBlock Margin="28,0,0,0"
                                       Style="{StaticResource SectionBodyStyle}"
                                       Text="Appends compact JSON log entries under Local AppData so you can inspect ignored windows, release decisions, and animation plans if something feels off." />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Margin="20,14,20,20"
                Padding="18"
                CornerRadius="22"
                Background="#0E1829"
                BorderBrush="#223753"
                BorderThickness="1">
            <DockPanel LastChildFill="False">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Foreground="#F8FAFC"
                               FontWeight="SemiBold"
                               Text="Apply changes" />
                    <TextBlock Foreground="#9CB3D1"
                               Text="Save updates the running tray app immediately." />
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Width="106"
                        Margin="12,0,0,0"
                        Padding="0,12"
                        Background="#F97316"
                        BorderThickness="0"
                        Click="SaveButton_OnClick"
                        Content="Save"
                        Foreground="White"
                        FontWeight="SemiBold" />

                <Button DockPanel.Dock="Right"
                        Width="106"
                        Padding="0,12"
                        Background="#18253A"
                        BorderBrush="#314A69"
                        BorderThickness="1"
                        Click="CancelButton_OnClick"
                        Content="Cancel"
                        Foreground="#E2E8F0"
                        FontWeight="SemiBold" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
